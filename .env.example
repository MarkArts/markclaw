# Slack Bot (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Claude authentication (one of these)
ANTHROPIC_API_KEY=sk-ant-...
# OR use OAuth: claude /login (stores in ~/.claude/.credentials.json)

# Model (optional, defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Slack user IDs allowed to interact (comma-separated)
SLACK_ALLOWED_USERS=U07XXXXXXXX

# GitHub org for web UI PR dashboard (optional)
GITHUB_ORG=your-org

# Jira site URL for web UI links (optional)
JIRA_SITE=https://your-org.atlassian.net
