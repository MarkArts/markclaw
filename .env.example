# Claude authentication — requires OAuth (run `claude /login` first)
# The host's ~/.claude/.credentials.json is mounted into agent containers.
# API keys are NOT supported — agents need full Claude Code CLI auth.

# Model (optional, defaults to claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Slack Bot — optional (Socket Mode). Without Slack, use the web UI.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=U07XXXXXXXX

# Web UI (optional)
# GITHUB_ORG=your-org
# JIRA_SITE=https://your-org.atlassian.net
