# Tool credentials injected as env vars into all agent containers.
# Copy this to .env-shared and fill in the ones you need.
# Only uncomment tools you actually use — agents work without any of these.

# GitHub — personal access token (repo scope)
# export GH_TOKEN="github_pat_..."

# Jira — API token + site URL + email
# export JIRA_API_TOKEN="..."
# export JIRA_SITE="https://your-org.atlassian.net"
# export JIRA_USER="you@company.com"

# Sentry — auth token
# export SENTRY_AUTH_TOKEN="sntryu_..."

# Heroku — API key
# export HEROKU_API_KEY="HRKU-..."

# Axiom — log querying
# export AXIOM_TOKEN="xaat-..."
# export AXIOM_ORG_ID="your-org-id"

# Grafana — self-hosted instance (view-only)
# export GRAFANA_SELFHOSTED_DEV_TOKEN="glsa_..."

# Slite — company wiki (used as MCP server)
# export SLITE_API_KEY="..."
